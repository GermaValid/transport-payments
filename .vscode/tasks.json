{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "go: build (debug sqlite3)",
        "type": "shell",
        "command": "go",
        "args": [
          "build",
          "-gcflags=all=-N -l",
          "-o",
          "${workspaceFolder}/__debug_bin.exe",
          "."
        ],
        "options": {
          "cwd": "${workspaceFolder}",
          "env": {
            "CGO_ENABLED": "1",
            "CC": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "CXX": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "CGO_CFLAGS": "-IC:/msys64/ucrt64/include",
            "CGO_LDFLAGS": "-LC:/msys64/ucrt64/lib",
            "PATH": "C:\\msys64\\ucrt64\\bin;C:\\Program Files\\Go\\bin;${env:PATH}"
          }
        },
        "problemMatcher": ["$go"]
      }
    ]
  }